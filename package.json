{
  "name": "@tursom/turntf-web-sdk",
  "version": "0.2.1",
  "description": "Browser SDK for turntf with full HTTP and WebSocket support.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tursom/turntf-web-sdk.git"
  },
  "homepage": "https://github.com/tursom/turntf-web-sdk#readme",
  "bugs": {
    "url": "https://github.com/tursom/turntf-web-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "proto",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:proto": "protoc -I proto --ts_out src/generated --ts_opt long_type_string proto/client.proto && node scripts/postprocess-generated.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "pack:check": "npm pack --dry-run --cache .npm-cache",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./proto/client.proto": "./proto/client.proto",
    "./package.json": "./package.json"
  },
  "keywords": [
    "turntf",
    "sdk",
    "browser",
    "typescript",
    "websocket",
    "protobuf"
  ],
  "dependencies": {
    "@protobuf-ts/runtime": "^2.11.1",
    "bcryptjs": "^3.0.2",
    "json-bigint": "^1.0.0"
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "ws": "^8.18.3"
  }
}
